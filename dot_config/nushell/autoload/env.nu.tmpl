##### Default env variables #####
$env.DOCKER_BUILDKIT = 1
$env.STARSHIP_CONFIG = $env.HOME | path join '.config/starship.toml'
$env.OP_PLUGIN_ALIASES_SOURCED = 1

# work environment variables
{{- if .chezmoi.config.data.isWorkMachine }}
$env.VAULT_ADDR = 'https://vault.infra.subsplash.io'
$env.HELM_EXPERIMENTAL_OCI = 1
$env.HELM_S3_MODE = '3'
{{- end }}

# add overlays here
use std/dirs shells-aliases *
use git
use opencode.nu

# aliases have to come last or they will reference the original commands
use aliases *
