#!/opt/homebrew/bin/nu

{{- if eq .chezmoi.os "darwin" }}
with-env { HOMEBREW_NO_ENV_HINTS: 1 HOMEBREW_BUNDLE_INSTALL_CLEANUP: 1 } {
  use std/util "path add"
  use std/dirs

  print "🍺  Installing packages with brew..."
  brew bundle install
  brew bundle --force cleanup

  mktemp -d nupm.XXX | dirs add $in
  http get --raw https://github.com/nushell/nupm/archive/refs/heads/main.zip | save nupm-main.zip
  unzip nupm-main.zip

  ($env.HOME | path join ".local/share/nupm")
    | do {
        rm -rf $in
        mv nupm-main/nupm $in
      }
}
{{- end }}
